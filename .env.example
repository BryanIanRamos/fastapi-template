# =============================
# Database
# =============================
# Default (local SQLite)
DATABASE_URL=postgresql://postgres:moymoybryan@localhost:5432/fastapi_db

# If using PostgreSQL, put USERNAME and PASSWORD here:
# Format: postgresql+psycopg2://<USERNAME>:<PASSWORD>@<HOST>:<PORT>/<DB_NAME>
# Example:
# DATABASE_URL=postgresql+psycopg2://myuser:mypassword@localhost:5432/fastapi_db

# If using MySQL, put USERNAME and PASSWORD here:
# Format: mysql+pymysql://<USERNAME>:<PASSWORD>@<HOST>:<PORT>/<DB_NAME>
# Example:
# DATABASE_URL=mysql+pymysql://myuser:mypassword@localhost:3306/fastapi_db

# Note: If your password has special characters (@, :, /, #), URL-encode it.

# =============================
# App
# =============================
API_V1_STR=/api/v1
PROJECT_NAME=FastAPI Server
DEBUG=True

# =============================
# Auth (JWT)
# =============================
SECRET_KEY=change-this-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
